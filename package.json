{
  "name": "memowl",
  "displayName": "Memowl",
  "description": "Browse and manage GitHub Copilot's native agent memories, with scope awareness and workspace-hash mapping.",
  "version": "0.0.1",
  "publisher": "memowl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jlieuw/memowl.git"
  },
  "bugs": {
    "url": "https://github.com/jlieuw/memowl/issues"
  },
  "homepage": "https://github.com/jlieuw/memowl#readme",
  "pricing": "Free",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "copilot",
    "memory",
    "agent",
    "ai",
    "memories"
  ],
  "icon": "media/memowl-icon.png",
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "memowl",
          "title": "Memowl",
          "icon": "media/memowl.svg"
        }
      ]
    },
    "views": {
      "memowl": [
        {
          "id": "memowl.memories",
          "name": "Copilot Memories",
          "icon": "media/memowl.svg",
          "contextualTitle": "Memowl"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "memowl.memories",
        "contents": "No Copilot memory store was found yet.\nMemories are created by Copilot's agent as you work. You can also create one now.\n[Create a memory](command:memowl.newMemory)\n[Refresh](command:memowl.refresh)"
      }
    ],
    "commands": [
      {
        "command": "memowl.refresh",
        "title": "Refresh",
        "category": "Memowl",
        "icon": "$(refresh)"
      },
      {
        "command": "memowl.newMemory",
        "title": "New Memory...",
        "category": "Memowl",
        "icon": "$(add)"
      },
      {
        "command": "memowl.newMemoryHere",
        "title": "New Memory Here...",
        "category": "Memowl",
        "icon": "$(new-file)"
      },
      {
        "command": "memowl.openMemory",
        "title": "Open Memory",
        "category": "Memowl"
      },
      {
        "command": "memowl.deleteMemory",
        "title": "Delete",
        "category": "Memowl",
        "icon": "$(trash)"
      },
      {
        "command": "memowl.revealInOS",
        "title": "Reveal in File Explorer",
        "category": "Memowl"
      },
      {
        "command": "memowl.copyPath",
        "title": "Copy Path",
        "category": "Memowl"
      },
      {
        "command": "memowl.openStorageFolder",
        "title": "Open Storage Folder",
        "category": "Memowl",
        "icon": "$(folder-opened)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "memowl.newMemory",
          "when": "view == memowl.memories",
          "group": "navigation@1"
        },
        {
          "command": "memowl.refresh",
          "when": "view == memowl.memories",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "memowl.newMemoryHere",
          "when": "view == memowl.memories && (viewItem == memoryRoot || viewItem == memoryFolder)",
          "group": "inline@1"
        },
        {
          "command": "memowl.openStorageFolder",
          "when": "view == memowl.memories && viewItem == memoryRoot",
          "group": "inline@2"
        },
        {
          "command": "memowl.deleteMemory",
          "when": "view == memowl.memories && (viewItem == memoryFile || viewItem == memoryFolder)",
          "group": "inline@3"
        },
        {
          "command": "memowl.openMemory",
          "when": "view == memowl.memories && viewItem == memoryFile",
          "group": "1_open@1"
        },
        {
          "command": "memowl.revealInOS",
          "when": "view == memowl.memories && (viewItem == memoryFile || viewItem == memoryFolder || viewItem == memoryRoot)",
          "group": "2_files@1"
        },
        {
          "command": "memowl.copyPath",
          "when": "view == memowl.memories && (viewItem == memoryFile || viewItem == memoryFolder)",
          "group": "2_files@2"
        },
        {
          "command": "memowl.deleteMemory",
          "when": "view == memowl.memories && (viewItem == memoryFile || viewItem == memoryFolder)",
          "group": "3_modify@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:icon": "node scripts/build-icon.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.96.0",
    "sharp": "^0.33.0",
    "typescript": "^5.4.0"
  }
}
